#include <stm32f401re gpio.h>
#include <stm32f401re_rcc.h>
uint8_t button_old = 1;
uint8_t button_new;

while (1)
{
    button_new = HAL_GPIO_ReadPin(GPIOC, GPIO_PIN_13);

    // phát hiện nhấn nút (cạnh xuống)
    if(button_old == 1 && button_new == 0)
    {
        HAL_GPIO_TogglePin(GPIOA, GPIO_PIN_5);
        HAL_Delay(200); // chống dội (debounce)
    }

    button_old = button_new;
}
